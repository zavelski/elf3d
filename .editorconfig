root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yaml,yml}]
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.{png,jpg,jpeg,gif,ico,ttf,glb,zip,7z,tar,gz}]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

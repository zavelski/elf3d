{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-debug",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ELF3D_BUILD_ENGINE": "ON",
        "ELF3D_BUILD_VIEWER": "ON"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-release",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ELF3D_BUILD_ENGINE": "ON",
        "ELF3D_BUILD_VIEWER": "ON"
      }
    },
    {
      "name": "windows-model-debug",
      "displayName": "Windows x64 Model Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-model-debug",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ELF3D_BUILD_ENGINE": "OFF",
        "ELF3D_BUILD_VIEWER": "OFF"
      }
    },
    {
      "name": "windows-model-release",
      "displayName": "Windows x64 Model Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-model-release",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release",
        "ELF3D_BUILD_ENGINE": "OFF",
        "ELF3D_BUILD_VIEWER": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "windows-model-debug",
      "configurePreset": "windows-model-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-model-release",
      "configurePreset": "windows-model-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-model-debug",
      "configurePreset": "windows-model-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-model-release",
      "configurePreset": "windows-model-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
